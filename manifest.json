{
  "manifest_version": 3,
  "name": "Chess.com 한국어 리뷰",
  "version": "1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.chess.com/*"
      ],
      "js": [
        "dict.js",
        "main.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "back.js"
  },
  "options_page": "settings.html"
}